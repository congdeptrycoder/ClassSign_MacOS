{
  "name": "app-test",
  "version": "1.0.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --dir",
    "pack:win": "electron-vite build && electron-builder --win --x64",
    "pack:mac": "electron-vite build && electron-builder --mac",
    "preview": "electron-vite preview",
    "start": "electron .",
    "server": "tsx server/index.ts",
    "test": "vitest"
  },
  "build": {
    "appId": "com.congchi.class-registration",
    "productName": "Class Registration",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/infrastructure/database/database.sqlite",
        "to": "database.sqlite"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^1.0.3",
    "@electron-toolkit/utils": "^3.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.9",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.9"
  }
}
